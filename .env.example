# Environment Variables for WebRTC TURN server (e.g. from Metered Video or Twilio)
# Create a free account at https://www.metered.ca/webrtc-turn-server to get these.
# Multiple URLs can be separated by commas.
VITE_TURN_URL=turn:your-server.metered.ca:80,turn:your-server.metered.ca:443,turn:your-server.metered.ca:443?transport=tcp
VITE_TURN_USERNAME=your_username
VITE_TURN_CREDENTIAL=your_credential
